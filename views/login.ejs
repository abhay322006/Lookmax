<script>
/* ── RAIN ANIMATION ────────────────────────────── */
(function() {
  const canvas = document.getElementById('rain');
  const ctx = canvas.getContext('2d');
  let drops = [];

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    drops = Array.from({length: 120}, () => ({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      len: Math.random() * 18 + 8,
      speed: Math.random() * 3 + 2,
      opacity: Math.random() * 0.4 + 0.1
    }));
  }
  window.addEventListener('resize', resize); resize();

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    drops.forEach(d => {
      ctx.strokeStyle = `rgba(0,194,255,${d.opacity})`;
      ctx.lineWidth = 0.6;
      ctx.beginPath();
      ctx.moveTo(d.x, d.y);
      ctx.lineTo(d.x - 1, d.y + d.len);
      ctx.stroke();
      d.y += d.speed;
      if (d.y > canvas.height) {
        d.y = -d.len;
        d.x = Math.random() * canvas.width;
      }
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

/* ── HELPERS ───────────────────────────────────── */
const g = id => document.getElementById(id);

function showE(field, msg) {
  g(field).classList.add('invalid'); g(field).classList.remove('valid');
  g('err-' + (field==='email'?'email':'pw') + '-t').textContent = msg;
  g('err-' + (field==='email'?'email':'pw')).classList.add('show');
}
function clearE(field) {
  g(field).classList.remove('invalid');
  g('err-' + (field==='email'?'email':'pw')).classList.remove('show');
}
function validE(field) {
  g(field).classList.remove('invalid'); g(field).classList.add('valid');
  g('err-' + (field==='email'?'email':'pw')).classList.remove('show');
}

/* ── VALIDATION ────────────────────────────────── */
function vEmail(val, live=false) {
  if (!val.trim()) { if(!live) showE('email','Email or username is required'); else clearE('email'); return false; }
  const emailRx = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  // allow username (no @) or valid email
  if (val.includes('@') && !emailRx.test(val)) { showE('email','Enter a valid email address'); return false; }
  validE('email'); return true;
}

function vPw(val, live=false) {
  if (!val) { if(!live) showE('password','Password is required'); else clearE('password'); return false; }
  if (val.length < 6) { showE('password','Password must be at least 6 characters'); return false; }
  validE('password'); return true;
}

/* Real-time */
g('email').addEventListener('input',   e => vEmail(e.target.value, true));
g('email').addEventListener('blur',    e => vEmail(e.target.value));
g('password').addEventListener('input', e => vPw(e.target.value, true));
g('password').addEventListener('blur',  e => vPw(e.target.value));

/* ── EYE TOGGLE ────────────────────────────────── */
g('eyeBtn').addEventListener('click', () => {
  const pw = g('password'), show = pw.type === 'password';
  pw.type = show ? 'text' : 'password';
  g('eyeOn').style.display  = show ? 'none'  : 'block';
  g('eyeOff').style.display = show ? 'block' : 'none';
});

/* ── RIPPLE ────────────────────────────────────── */
g('btnLogin').addEventListener('click', function(e) {
  const btn = this, rect = btn.getBoundingClientRect();
  const d = Math.max(btn.clientWidth, btn.clientHeight);
  const r = document.createElement('span');
  r.className = 'ripple';
  r.style.cssText = `width:${d}px;height:${d}px;left:${e.clientX-rect.left-d/2}px;top:${e.clientY-rect.top-d/2}px;`;
  btn.querySelector('.ripple')?.remove();
  btn.appendChild(r);
  r.addEventListener('animationend', () => r.remove());
});

/* ── FORM SUBMIT ───────────────────────────────── */
g('loginForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const em = g('email').value, pw = g('password').value;
  const ok = [vEmail(em), vPw(pw)];

  if (ok.includes(false)) {
    ['email','password'].forEach(id => {
      if (g(id).classList.contains('invalid')) {
        g(id).classList.remove('shake');
        void g(id).offsetWidth;
        g(id).classList.add('shake');
        g(id).addEventListener('animationend', () => g(id).classList.remove('shake'), {once:true});
      }
    });
    return;
  }

  /* loading */
  const btn = g('btnLogin');
  btn.classList.add('loading'); btn.disabled = true;
  g('spinner').style.display = 'block';

  await new Promise(r => setTimeout(r, 2000));

  btn.classList.remove('loading'); btn.disabled = false;
  g('spinner').style.display = 'none';

  /* success */
  /* success */
const overlay = g('successOverlay');
g('successSub').textContent = `Authenticated as ${em}`;
overlay.classList.add('show');

setTimeout(() => {
  g('scanFill').style.width = '100%';
}, 120);

/* redirect to main project page */
setTimeout(() => {
  window.location.href = "/index.ejs";   // ya /home.html jo tera main page ho
}, 2500);
</script>
