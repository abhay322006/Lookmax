<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LOOKMAX AI — Sign In</title>

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet">

<style>
body{
  margin:0;
  font-family:'Outfit',sans-serif;
  background:#04060D;
  color:#fff;
  display:flex;
  align-items:center;
  justify-content:center;
  height:100vh;
}

.card{
  width:100%;
  max-width:400px;
  background:#0A1020;
  padding:30px;
  border-radius:16px;
  box-shadow:0 20px 60px rgba(0,0,0,0.8);
}

h1{
  text-align:center;
  font-family:'Rajdhani',sans-serif;
  letter-spacing:2px;
}

.field{
  margin-top:15px;
}

input{
  width:100%;
  padding:12px;
  border-radius:8px;
  border:1px solid #222;
  background:#111;
  color:#fff;
  outline:none;
}

input:focus{
  border-color:#00C2FF;
}

.err{
  font-size:12px;
  color:#FF2D55;
  display:none;
}

button{
  margin-top:20px;
  width:100%;
  padding:12px;
  border:none;
  border-radius:8px;
  background:#0D6EFD;
  color:#fff;
  font-weight:bold;
  cursor:pointer;
}

button:disabled{
  opacity:0.6;
}

.success{
  display:none;
  text-align:center;
  margin-top:20px;
  color:#00FF88;
}
</style>
</head>

<body>

<div class="card">
  <h1>LOOKMAX AI</h1>

  <form id="form" method="post" action="/register">

    <!-- Username -->
    <div class="field">
      <input type="text" id="username" name="username" placeholder="Username">
      <div class="err" id="err-user">Username required</div>
    </div>

    <!-- Email -->
    <div class="field">
      <input type="email" id="email" name="email" placeholder="Email">
      <div class="err" id="err-email">Valid email required</div>
    </div>

    <!-- Password -->
    <div class="field">
      <input type="password" id="password" name="password" placeholder="Password (min 6 chars)">
      <div class="err" id="err-pass">Min 6 characters</div>
    </div>

    <button type="submit" id="btn">LOGIN</button>

    <div class="success" id="success">Login Successful ⚡</div>

  </form>
</div>

<script>
const g=id=>document.getElementById(id);

function vUser(){
  if(!g('username').value.trim()){
    g('err-user').style.display='block';
    return false;
  }
  g('err-user').style.display='none';
  return true;
}

function vEmail(){
  const val=g('email').value;
  const ok=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
  if(!ok){
    g('err-email').style.display='block';
    return false;
  }
  g('err-email').style.display='none';
  return true;
}

function vPass(){
  if(g('password').value.length<6){
    g('err-pass').style.display='block';
    return false;
  }
  g('err-pass').style.display='none';
  return true;
}

g('form').addEventListener('submit',e=>{
  e.preventDefault();

  if(!(vUser() & vEmail() & vPass())) return;

  const btn=g('btn');
  btn.disabled=true;
  btn.innerText='LOADING...';

  g('form').submit();
});
</script>

</body>
</html>