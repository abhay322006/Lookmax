<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LOOKMAX AI — Sign In</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --black: #04060D;
      --deep: #070C1A;
      --panel: #0A1020;
      --blue: #0D6EFD;
      --cyan: #00C2FF;
      --cyan-dim: rgba(0,194,255,0.15);
      --red: #FF2D55;
      --white: #FFFFFF;
      --offwhite: #C8D6F0;
      --muted: #6C7A96;
      --glass: rgba(10,16,32,0.78);
      --border: rgba(0,194,255,0.16);
      --success: #00E38C;
    }

    body {
      min-height: 100vh;
      overflow-x: hidden;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--black);
      color: var(--white);
      position: relative;
    }

    /* ===== BACKGROUND ===== */
    .bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(circle at 20% 20%, rgba(0,194,255,0.12), transparent 25%),
        radial-gradient(circle at 80% 30%, rgba(13,110,253,0.12), transparent 25%),
        radial-gradient(circle at 50% 80%, rgba(255,45,85,0.08), transparent 28%),
        linear-gradient(180deg, #04060D 0%, #07101D 50%, #04060D 100%);
    }

    .grid-overlay {
      position: fixed;
      inset: 0;
      z-index: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      mask-image: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent 90%);
      pointer-events: none;
    }

    canvas#rain {
      position: fixed;
      inset: 0;
      z-index: 0;
      opacity: 0.22;
      pointer-events: none;
    }

    .scanlines {
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background: repeating-linear-gradient(
        to bottom,
        rgba(255,255,255,0.02) 0px,
        rgba(255,255,255,0.02) 1px,
        transparent 2px,
        transparent 4px
      );
      opacity: 0.2;
    }

    .page {
      position: relative;
      z-index: 2;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 16px;
    }

    /* ===== CARD ===== */
    .card {
      width: 100%;
      max-width: 430px;
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: 22px;
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      box-shadow:
        0 30px 70px rgba(0,0,0,0.7),
        0 0 60px rgba(0,194,255,0.06);
      overflow: hidden;
      position: relative;
      animation: cardIn .6s ease;
    }

    @keyframes cardIn {
      from {
        opacity: 0;
        transform: translateY(20px) scale(.98);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 12%;
      width: 76%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    }

    .card-header {
      padding: 34px 28px 24px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      text-align: center;
      position: relative;
    }

    .logo-wrap {
      width: 64px;
      height: 64px;
      margin: 0 auto 16px;
      border-radius: 50%;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(0,194,255,0.25);
      box-shadow: 0 0 30px rgba(0,194,255,0.12);
      overflow: hidden;
    }

    .logo-wrap::before {
      content: "";
      position: absolute;
      inset: -30%;
      background: conic-gradient(from 0deg, transparent, rgba(0,194,255,0.4), transparent);
      animation: rotateRing 4s linear infinite;
    }

    .logo-inner {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: rgba(4,6,13,0.9);
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--cyan);
      font-size: 24px;
      box-shadow: inset 0 0 20px rgba(0,194,255,0.08);
    }

    @keyframes rotateRing {
      to { transform: rotate(360deg); }
    }

    .brand {
      font-size: 30px;
      font-weight: 800;
      letter-spacing: 4px;
      color: white;
      margin-bottom: 8px;
      text-transform: uppercase;
    }

    .brand span {
      color: var(--cyan);
      text-shadow: 0 0 14px rgba(0,194,255,0.35);
    }

    .tagline {
      font-size: 12px;
      color: var(--muted);
      letter-spacing: 2px;
      text-transform: uppercase;
      line-height: 1.5;
    }

    .card-body {
      padding: 28px;
    }

    .form-title {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 22px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .form-title::after {
      content: "";
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, rgba(0,194,255,0.2), transparent);
    }

    .field {
      margin-bottom: 18px;
    }

    .field label {
      display: block;
      margin-bottom: 8px;
      font-size: 12px;
      color: var(--offwhite);
      letter-spacing: 1px;
    }

    .input-wrap {
      position: relative;
    }

    .input-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      font-size: 16px;
      pointer-events: none;
    }

    .input {
      width: 100%;
      height: 50px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      color: white;
      padding: 0 46px 0 42px;
      font-size: 14px;
      outline: none;
      transition: .25s ease;
    }

    .input::placeholder {
      color: rgba(200,214,240,0.35);
    }

    .input:focus {
      border-color: rgba(0,194,255,0.55);
      box-shadow: 0 0 0 3px rgba(0,194,255,0.12);
      background: rgba(0,194,255,0.04);
    }

    .input.valid {
      border-color: rgba(0,227,140,0.45);
      box-shadow: 0 0 0 3px rgba(0,227,140,0.08);
    }

    .input.invalid {
      border-color: rgba(255,45,85,0.6);
      box-shadow: 0 0 0 3px rgba(255,45,85,0.1);
      background: rgba(255,45,85,0.04);
    }

    .toggle-password {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: transparent;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 13px;
      padding: 4px;
    }

    .toggle-password:hover {
      color: var(--cyan);
    }

    .error {
      min-height: 18px;
      margin-top: 6px;
      font-size: 12px;
      color: var(--red);
      opacity: 0;
      transform: translateY(-3px);
      transition: .2s ease;
    }

    .error.show {
      opacity: 1;
      transform: translateY(0);
    }

    .row {
      margin-top: 8px;
      margin-bottom: 18px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .remember {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: var(--muted);
      cursor: pointer;
    }

    .remember input {
      accent-color: var(--cyan);
      width: 15px;
      height: 15px;
      cursor: pointer;
    }

    .forgot {
      font-size: 13px;
      color: var(--cyan);
      text-decoration: none;
    }

    .forgot:hover {
      text-decoration: underline;
    }

    .btn {
      width: 100%;
      height: 52px;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      color: white;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      background: linear-gradient(135deg, #0D6EFD 0%, #00C2FF 100%);
      box-shadow: 0 10px 30px rgba(13,110,253,0.35);
      position: relative;
      overflow: hidden;
      transition: .2s ease;
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 36px rgba(13,110,253,0.45);
    }

    .btn:disabled {
      opacity: .75;
      cursor: not-allowed;
      transform: none;
    }

    .btn::before {
      content: "";
      position: absolute;
      top: 0;
      left: -120%;
      width: 70%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.28), transparent);
      transform: skewX(-20deg);
      transition: .5s;
    }

    .btn:hover::before {
      left: 160%;
    }

    .btn-content {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
    }

    .spinner {
      width: 18px;
      height: 18px;
      border: 2px solid rgba(255,255,255,0.35);
      border-top-color: white;
      border-radius: 50%;
      display: none;
      animation: spin .7s linear infinite;
    }

    .btn.loading .spinner {
      display: block;
    }

    .btn.loading .btn-text {
      opacity: .9;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .server-error {
      margin-top: 14px;
      text-align: center;
      color: var(--red);
      font-size: 13px;
      min-height: 18px;
    }

    .footer {
      border-top: 1px solid rgba(255,255,255,0.05);
      padding: 18px 28px 24px;
      text-align: center;
      color: var(--muted);
      font-size: 13px;
    }

    .footer a {
      color: var(--cyan);
      text-decoration: none;
      font-weight: 600;
    }

    .footer a:hover {
      text-decoration: underline;
    }

    /* ===== SUCCESS OVERLAY ===== */
    .success-overlay {
      position: fixed;
      inset: 0;
      background: rgba(4,6,13,0.95);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 16px;
      z-index: 100;
      opacity: 0;
      pointer-events: none;
      transition: .35s ease;
    }

    .success-overlay.show {
      opacity: 1;
      pointer-events: all;
    }

    .success-ring {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      border: 1px solid rgba(0,194,255,0.35);
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: pulseRing 1.8s infinite ease-in-out;
      box-shadow: 0 0 40px rgba(0,194,255,0.12);
    }

    .success-ring::before,
    .success-ring::after {
      content: "";
      position: absolute;
      border-radius: 50%;
      inset: 10px;
      border: 1px dashed rgba(0,194,255,0.25);
    }

    .success-ring::after {
      inset: -12px;
      border-style: solid;
      opacity: 0.4;
      animation: rotateRing 4s linear infinite;
    }

    @keyframes pulseRing {
      0%,100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }

    .success-icon {
      font-size: 34px;
      color: var(--cyan);
      text-shadow: 0 0 20px rgba(0,194,255,0.4);
    }

    .success-title {
      font-size: 28px;
      font-weight: 800;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: white;
      text-align: center;
    }

    .success-sub {
      color: var(--muted);
      font-size: 14px;
      text-align: center;
      padding: 0 20px;
    }

    .progress {
      width: 240px;
      height: 6px;
      border-radius: 999px;
      background: rgba(255,255,255,0.08);
      overflow: hidden;
    }

    .progress-fill {
      width: 0%;
      height: 100%;
      background: linear-gradient(90deg, #0D6EFD, #00C2FF);
      transition: width 1.3s ease;
    }

    @media (max-width: 480px) {
      .card-header, .card-body, .footer {
        padding-left: 20px;
        padding-right: 20px;
      }

      .brand {
        font-size: 24px;
      }

      .tagline {
        font-size: 11px;
      }
    }
  </style>
</head>
<body>

  <canvas id="rain"></canvas>
  <div class="bg"></div>
  <div class="grid-overlay"></div>
  <div class="scanlines"></div>

  <!-- success overlay -->
  <div class="success-overlay" id="successOverlay">
    <div class="success-ring">
      <div class="success-icon">⚡</div>
    </div>
    <div class="success-title">Identity Verified</div>
    <div class="success-sub" id="successSub">Logging you into Lookmax AI...</div>
    <div class="progress">
      <div class="progress-fill" id="progressFill"></div>
    </div>
  </div>

  <div class="page">
    <div class="card">
      <div class="card-header">
        <div class="logo-wrap">
          <div class="logo-inner">◉</div>
        </div>

        <div class="brand">LOOKMAX <span>AI</span></div>
        <div class="tagline">Face · Body · Evolution Engine</div>
      </div>

      <div class="card-body">
        <div class="form-title">Authenticate</div>

        <form id="loginForm" method="POST" action="/login" novalidate>
          <div class="field">
            <label for="identifier">Email or Username</label>
            <div class="input-wrap">
              <span class="input-icon">✦</span>
              <input
                class="input"
                type="text"
                id="identifier"
                name="identifier"
                placeholder="Enter email or username"
                autocomplete="off"
              />
            </div>
            <div class="error" id="identifierError"></div>
          </div>

          <div class="field">
            <label for="password">Password</label>
            <div class="input-wrap">
              <span class="input-icon">✦</span>
              <input
                class="input"
                type="password"
                id="password"
                name="password"
                placeholder="Minimum 6 characters"
                autocomplete="current-password"
              />
              <button class="toggle-password" type="button" id="togglePassword">SHOW</button>
            </div>
            <div class="error" id="passwordError"></div>
          </div>

          <div class="row">
            <label class="remember">
              <input type="checkbox" name="rememberMe" />
              Remember me
            </label>
            <a href="#" class="forgot">Forgot password?</a>
          </div>

          <button type="submit" class="btn" id="loginBtn">
            <div class="btn-content">
              <div class="spinner" id="spinner"></div>
              <span class="btn-text">Initialize Scan</span>
            </div>
          </button>

          <div class="server-error">
            <%= typeof error !== 'undefined' ? error : '' %>
          </div>
        </form>
      </div>

      <div class="footer">
      <p>New to Lookmax? <a href="/">Begin your evolution →</a></p>
      </div>
    </div>
  </div>

  <script>
    /* =========================
       RAIN EFFECT
    ========================== */
    (function () {
      const canvas = document.getElementById("rain");
      const ctx = canvas.getContext("2d");
      let drops = [];

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        drops = Array.from({ length: 130 }, () => ({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          len: Math.random() * 20 + 8,
          speed: Math.random() * 3 + 2,
          opacity: Math.random() * 0.35 + 0.08
        }));
      }

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (const d of drops) {
          ctx.beginPath();
          ctx.strokeStyle = `rgba(0,194,255,${d.opacity})`;
          ctx.lineWidth = 0.7;
          ctx.moveTo(d.x, d.y);
          ctx.lineTo(d.x - 1, d.y + d.len);
          ctx.stroke();

          d.y += d.speed;
          if (d.y > canvas.height) {
            d.y = -d.len;
            d.x = Math.random() * canvas.width;
          }
        }
        requestAnimationFrame(draw);
      }

      window.addEventListener("resize", resize);
      resize();
      draw();
    })();

    /* =========================
       HELPERS
    ========================== */
    const loginForm = document.getElementById("loginForm");
    const identifier = document.getElementById("identifier");
    const password = document.getElementById("password");
    const identifierError = document.getElementById("identifierError");
    const passwordError = document.getElementById("passwordError");
    const togglePassword = document.getElementById("togglePassword");
    const loginBtn = document.getElementById("loginBtn");
    const successOverlay = document.getElementById("successOverlay");
    const successSub = document.getElementById("successSub");
    const progressFill = document.getElementById("progressFill");

    function showError(input, errorEl, msg) {
      input.classList.remove("valid");
      input.classList.add("invalid");
      errorEl.textContent = msg;
      errorEl.classList.add("show");
    }

    function clearError(input, errorEl) {
      input.classList.remove("invalid");
      errorEl.textContent = "";
      errorEl.classList.remove("show");
    }

    function showValid(input, errorEl) {
      input.classList.remove("invalid");
      input.classList.add("valid");
      errorEl.textContent = "";
      errorEl.classList.remove("show");
    }

    function validateIdentifier(live = false) {
      const value = identifier.value.trim();

      if (!value) {
        if (!live) showError(identifier, identifierError, "Email ya username required hai");
        else clearError(identifier, identifierError);
        return false;
      }

      // agar email format me likha hai to validate kar lo
      if (value.includes("@")) {
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(value)) {
          showError(identifier, identifierError, "Valid email enter karo");
          return false;
        }
      }

      showValid(identifier, identifierError);
      return true;
    }

    function validatePassword(live = false) {
      const value = password.value;

      if (!value) {
        if (!live) showError(password, passwordError, "Password required hai");
        else clearError(password, passwordError);
        return false;
      }

      if (value.length < 6) {
        showError(password, passwordError, "Password minimum 6 characters ka hona chahiye");
        return false;
      }

      showValid(password, passwordError);
      return true;
    }

    identifier.addEventListener("input", () => validateIdentifier(true));
    identifier.addEventListener("blur", () => validateIdentifier(false));
    password.addEventListener("input", () => validatePassword(true));
    password.addEventListener("blur", () => validatePassword(false));

    togglePassword.addEventListener("click", () => {
      if (password.type === "password") {
        password.type = "text";
        togglePassword.textContent = "HIDE";
      } else {
        password.type = "password";
        togglePassword.textContent = "SHOW";
      }
    });

    /* =========================
       SUBMIT LOGIC
       IMPORTANT:
       - pehle front-end validation
       - phir success animation
       - phir actual form submit
    ========================== */
    loginForm.addEventListener("submit", async function (e) {
      e.preventDefault();

      const ok1 = validateIdentifier(false);
      const ok2 = validatePassword(false);

      if (!ok1 || !ok2) return;

      loginBtn.disabled = true;
      loginBtn.classList.add("loading");

      // thoda fake processing
      await new Promise(resolve => setTimeout(resolve, 900));

      successSub.textContent = "Authenticated. Redirecting to Lookmax AI...";
      successOverlay.classList.add("show");

      setTimeout(() => {
        progressFill.style.width = "100%";
      }, 80);

      // 1.2 sec baad actual backend login route hit hoga
      setTimeout(() => {
        loginForm.submit();
      }, 1200);
    });
  </script>
</body>
</html>