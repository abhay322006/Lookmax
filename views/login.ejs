<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LOOKMAX AI — Sign In</title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet"/>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root{
      --black:#04060D;
      --deep:#070C1A;
      --panel:#0A1020;
      --blue:#0D6EFD;
      --cyan:#00C2FF;
      --red:#FF2D55;
      --white:#fff;
      --muted:#4A6080;
      --glass:rgba(10,16,32,0.75);
      --border:rgba(0,194,255,0.12);
    }

    html, body{
      min-height:100%;
      overflow-x:hidden;
      font-family:'Outfit', sans-serif;
      background:var(--black);
      color:var(--white);
    }

    #rain{
      position:fixed;
      inset:0;
      z-index:0;
      pointer-events:none;
      opacity:0.18;
    }

    .bg{
      position:fixed;
      inset:0;
      z-index:0;
      background:
        radial-gradient(ellipse 55% 40% at 20% 80%, rgba(13,110,253,0.12) 0%, transparent 60%),
        radial-gradient(ellipse 50% 45% at 80% 20%, rgba(0,194,255,0.08) 0%, transparent 60%),
        radial-gradient(ellipse 40% 35% at 50% 50%, rgba(255,45,85,0.04) 0%, transparent 70%),
        linear-gradient(180deg, #04060D 0%, #060B18 50%, #04060D 100%);
    }

    .scanlines{
      position:fixed;
      inset:0;
      z-index:1;
      pointer-events:none;
      background:repeating-linear-gradient(
        0deg,
        transparent 0px, transparent 2px,
        rgba(0,0,0,0.08) 2px, rgba(0,0,0,0.08) 4px
      );
    }

    .city-strip{
      position:fixed;
      bottom:0;
      left:0;
      right:0;
      height:220px;
      z-index:0;
      pointer-events:none;
      background:linear-gradient(180deg, transparent 0%, rgba(4,6,13,0.96) 100%);
    }
    .city-strip::before{
      content:'';
      position:absolute;
      bottom:0;
      left:0;
      right:0;
      height:160px;
      background:
        repeating-linear-gradient(90deg,
          #070C1A 0px, #070C1A 18px,
          transparent 18px, transparent 28px,
          #060B16 28px, #060B16 52px,
          transparent 52px, transparent 62px,
          #08101E 62px, #08101E 90px,
          transparent 90px, transparent 104px
        );
      opacity:0.6;
    }

    .status-bar{
      position:fixed;
      top:0; left:0; right:0;
      height:36px;
      z-index:5;
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:0 28px;
      border-bottom:1px solid rgba(0,194,255,0.06);
      background:rgba(4,6,13,0.7);
      backdrop-filter:blur(10px);
    }

    .status-logo{
      font-family:'Rajdhani', sans-serif;
      font-size:13px;
      font-weight:700;
      letter-spacing:0.3em;
      color:var(--cyan);
      text-transform:uppercase;
    }

    .status-dots{ display:flex; gap:8px; align-items:center; }
    .dot{ width:6px; height:6px; border-radius:50%; }
    .dot-g{ background:#00FF88; box-shadow:0 0 6px #00FF88; animation:pulse-dot 2s ease-in-out infinite; }
    .dot-r{ background:var(--red); opacity:0.6; }
    .dot-y{ background:#FFD600; opacity:0.6; }

    @keyframes pulse-dot{
      0%,100%{opacity:1;}
      50%{opacity:0.3;}
    }

    .status-right{
      font-size:10px;
      letter-spacing:0.15em;
      color:var(--muted);
      font-family:'Rajdhani', sans-serif;
    }

    .page{
      position:relative;
      z-index:3;
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:60px 16px 32px;
    }

    .card{
      width:100%;
      max-width:420px;
      background:var(--glass);
      backdrop-filter:blur(24px) saturate(1.5);
      border:1px solid var(--border);
      border-radius:20px;
      box-shadow:
        0 0 0 1px rgba(0,194,255,0.05) inset,
        0 40px 80px rgba(0,0,0,0.8),
        0 0 60px rgba(0,194,255,0.06);
      overflow:visible;
      position:relative;
      animation:cardIn 0.7s cubic-bezier(0.22,1,0.36,1) both;
    }

    @keyframes cardIn{
      from{ opacity:0; transform:translateY(24px) scale(0.97); }
      to{ opacity:1; transform:translateY(0) scale(1); }
    }

    .card::before{
      content:'';
      position:absolute;
      top:0; left:10%; right:10%;
      height:1px;
      background:linear-gradient(90deg, transparent, var(--cyan), transparent);
    }

    .scan-indicator{
      position:absolute;
      top:-1px;
      left:50%;
      transform:translateX(-50%);
      width:80px;
      height:3px;
      background:linear-gradient(90deg, transparent, var(--cyan), transparent);
      animation:scanPulse 2.5s ease-in-out infinite;
      border-radius:2px;
    }

    @keyframes scanPulse{
      0%,100%{opacity:0.4; width:60px;}
      50%{opacity:1; width:100px;}
    }

    .card-header{
      padding:36px 36px 24px;
      text-align:center;
      border-bottom:1px solid rgba(0,194,255,0.06);
      position:relative;
    }

    .ai-eye{
      width:56px; height:56px;
      margin:0 auto 20px;
      position:relative;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .eye-ring{
      position:absolute;
      inset:0;
      border-radius:50%;
      border:1px solid rgba(0,194,255,0.35);
      animation:ringRotate 8s linear infinite;
    }

    .eye-ring-2{
      position:absolute;
      inset:6px;
      border-radius:50%;
      border:1px dashed rgba(0,194,255,0.15);
      animation:ringRotate 5s linear infinite reverse;
    }

    .eye-glow{
      position:absolute;
      inset:-8px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(0,194,255,0.12) 0%, transparent 70%);
      animation:eyeBreath 3s ease-in-out infinite;
    }

    @keyframes ringRotate{ to{ transform:rotate(360deg); } }
    @keyframes eyeBreath{
      0%,100%{transform:scale(1); opacity:0.8;}
      50%{transform:scale(1.2); opacity:1;}
    }

    .brand-name{
      font-family:'Rajdhani', sans-serif;
      font-size:28px;
      font-weight:700;
      letter-spacing:0.22em;
      text-transform:uppercase;
      background:linear-gradient(135deg, #fff 0%, var(--cyan) 60%, #fff 100%);
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
      background-clip:text;
      margin-bottom:4px;
    }

    .brand-tag{
      font-size:10px;
      letter-spacing:0.3em;
      color:var(--muted);
      text-transform:uppercase;
      font-family:'Rajdhani', sans-serif;
    }
    .brand-tag span{ color:var(--cyan); }

    .card-body{ padding:28px 36px 36px; }

    .form-title{
      font-size:13px;
      font-weight:500;
      letter-spacing:0.18em;
      text-transform:uppercase;
      color:var(--muted);
      margin-bottom:24px;
      display:flex;
      align-items:center;
      gap:10px;
    }

    .form-title::after{
      content:'';
      flex:1;
      height:1px;
      background:linear-gradient(90deg, rgba(0,194,255,0.2), transparent);
    }

    .field{
      margin-bottom:22px;
      position:relative;
    }

    label.lbl{
      display:block;
      font-size:10.5px;
      font-weight:500;
      letter-spacing:0.18em;
      text-transform:uppercase;
      color:var(--muted);
      margin-bottom:10px;
      transition:color 0.2s;
    }

    .field:focus-within label.lbl{ color:var(--cyan); }

    .input-wrap{
      position:relative;
      display:flex;
      align-items:center;
    }

    .ico{
      position:absolute;
      left:14px;
      top:50%;
      transform:translateY(-50%);
      color:var(--muted);
      pointer-events:none;
      transition:color 0.25s;
      z-index:1;
    }

    .field:focus-within .ico{ color:var(--cyan); }

    input[type="text"], input[type="password"]{
      width:100%;
      height:50px;
      padding:0 14px 0 42px;
      background:rgba(255,255,255,0.03);
      border:1px solid rgba(255,255,255,0.07);
      border-radius:10px;
      color:var(--white);
      font-family:'Outfit', sans-serif;
      font-size:14.5px;
      outline:none;
      transition:border-color 0.25s, box-shadow 0.25s, background 0.25s;
    }

    input::placeholder{ color:rgba(74,96,128,0.7); }

    input:focus{
      border-color:rgba(0,194,255,0.5);
      background:rgba(0,194,255,0.04);
      box-shadow:0 0 0 3px rgba(0,194,255,0.1), 0 0 20px rgba(0,194,255,0.08);
    }

    input.invalid{
      border-color:rgba(255,45,85,0.6) !important;
      background:rgba(255,45,85,0.04) !important;
      box-shadow:0 0 0 3px rgba(255,45,85,0.1) !important;
    }

    input.valid{
      border-color:rgba(0,255,136,0.35);
    }

    input[type="password"]{ padding-right:46px; }

    .eye-btn{
      position:absolute;
      right:13px;
      top:50%;
      transform:translateY(-50%);
      background:none;
      border:none;
      cursor:pointer;
      padding:4px;
      color:var(--muted);
      display:flex;
      align-items:center;
      transition:color 0.2s;
    }

    .eye-btn:hover{ color:var(--cyan); }

    .err{
      font-size:11px;
      color:var(--red);
      margin-top:6px;
      padding-left:4px;
      display:flex;
      align-items:center;
      gap:5px;
      min-height:15px;
      opacity:0;
      transform:translateY(-4px);
      transition:opacity 0.22s, transform 0.22s;
    }

    .err.show{
      opacity:1;
      transform:translateY(0);
    }

    .row-mid{
      display:flex;
      align-items:center;
      justify-content:space-between;
      margin-bottom:22px;
      margin-top:4px;
    }

    .remember{
      display:flex;
      align-items:center;
      gap:8px;
      cursor:pointer;
      font-size:12.5px;
      color:var(--muted);
      user-select:none;
    }

    .remember input[type="checkbox"]{
      width:16px;
      height:16px;
      accent-color:var(--cyan);
      cursor:pointer;
    }

    .forgot{
      font-size:12px;
      color:var(--muted);
      text-decoration:none;
    }

    .forgot:hover{ color:var(--cyan); }

    .btn-login{
      width:100%;
      height:52px;
      margin-bottom:14px;
      background:linear-gradient(135deg, #0950C8 0%, #0D6EFD 40%, #00B4FF 100%);
      border:none;
      border-radius:10px;
      color:#fff;
      font-family:'Rajdhani', sans-serif;
      font-size:14px;
      font-weight:700;
      letter-spacing:0.28em;
      text-transform:uppercase;
      cursor:pointer;
      position:relative;
      overflow:hidden;
      box-shadow:0 6px 24px rgba(13,110,253,0.45), 0 0 40px rgba(0,194,255,0.1);
      transition:transform 0.18s, box-shadow 0.2s, filter 0.18s;
    }

    .btn-login:hover{
      transform:translateY(-2px);
      box-shadow:0 10px 36px rgba(13,110,253,0.6), 0 0 60px rgba(0,194,255,0.15);
      filter:brightness(1.08);
    }

    .btn-login:active{ transform:translateY(0) scale(0.98); }

    .btn-inner{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      position:relative;
      z-index:1;
    }

    .spinner{
      display:none;
      width:18px;
      height:18px;
      border:2px solid rgba(255,255,255,0.25);
      border-top-color:#fff;
      border-radius:50%;
      animation:spin 0.6s linear infinite;
    }

    @keyframes spin{ to{ transform:rotate(360deg); } }

    .btn-login.loading .spinner{ display:block; }

    .divider{
      display:flex;
      align-items:center;
      gap:12px;
      margin-bottom:14px;
      font-size:10px;
      letter-spacing:0.2em;
      color:var(--muted);
      text-transform:uppercase;
      font-family:'Rajdhani', sans-serif;
    }

    .divider::before, .divider::after{
      content:'';
      flex:1;
      height:1px;
      background:rgba(255,255,255,0.06);
    }

    .card-footer{
      padding:16px 36px 28px;
      border-top:1px solid rgba(0,194,255,0.05);
      text-align:center;
    }

    .card-footer p{
      font-size:12px;
      color:var(--muted);
    }

    .card-footer a{
      color:var(--cyan);
      text-decoration:none;
      font-weight:500;
    }

    .card-footer a:hover{ text-decoration:underline; }

    .secure{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:6px;
      margin-top:10px;
      font-size:10px;
      letter-spacing:0.12em;
      color:rgba(74,96,128,0.6);
      font-family:'Rajdhani', sans-serif;
      text-transform:uppercase;
    }

    .secure-dot{
      width:5px;
      height:5px;
      border-radius:50%;
      background:#00FF88;
      box-shadow:0 0 5px #00FF88;
      animation:pulse-dot 2s ease-in-out infinite;
    }

    @media (max-width:460px){
      .card-header, .card-body, .card-footer{
        padding-left:22px;
        padding-right:22px;
      }
      .brand-name{ font-size:22px; }
      .status-right{ display:none; }
    }
  </style>
</head>
<body>

<canvas id="rain"></canvas>
<div class="bg"></div>
<div class="scanlines"></div>
<div class="city-strip"></div>

<div class="status-bar">
  <div class="status-logo">Lookmax AI</div>
  <div class="status-dots">
    <div class="dot dot-r"></div>
    <div class="dot dot-y"></div>
    <div class="dot dot-g"></div>
  </div>
  <div class="status-right">SECURE · v2.4.1 · SYSTEM ONLINE</div>
</div>

<div class="page">
  <div class="card">
    <div class="scan-indicator"></div>

    <div class="card-header">
      <div class="ai-eye">
        <div class="eye-glow"></div>
        <div class="eye-ring"></div>
        <div class="eye-ring-2"></div>
        <svg width="28" height="28" viewBox="0 0 48 48" fill="none">
          <ellipse cx="24" cy="24" rx="20" ry="20" stroke="rgba(0,194,255,0.4)" stroke-width="1"/>
          <ellipse cx="24" cy="24" rx="10" ry="10" fill="rgba(0,194,255,0.12)" stroke="rgba(0,194,255,0.7)" stroke-width="1.5"/>
          <circle cx="24" cy="24" r="4" fill="rgba(0,194,255,0.9)"/>
          <circle cx="22" cy="22" r="1.5" fill="white" opacity="0.8"/>
          <line x1="4" y1="24" x2="44" y2="24" stroke="rgba(0,194,255,0.2)" stroke-width="0.5"/>
        </svg>
      </div>

      <div class="brand-name">LOOKMAX <span style="-webkit-text-fill-color:var(--cyan)">AI</span></div>
      <div class="brand-tag">FACE · BODY · <span>EVOLUTION ENGINE</span></div>
    </div>

    <div class="card-body">
      <div class="form-title">
        <svg width="10" height="10" viewBox="0 0 10 10">
          <circle cx="5" cy="5" r="4" fill="none" stroke="currentColor" stroke-width="1"/>
          <circle cx="5" cy="5" r="1.5" fill="currentColor"/>
        </svg>
        Authenticate
      </div>

      <!-- IMPORTANT: action and method -->
      <form id="loginForm" method="POST" action="/login">
        <!-- USERNAME -->
        <div class="field">
         
          <div class="input-wrap">
            <span class="ico">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21a8 8 0 0 0-16 0"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </span>
            <input type="text" id="username" name="username" placeholder="Enter your username" autocomplete="username"/>
          </div>
          <div class="err" id="err-user">
            <span id="err-user-t"></span>
          </div>
        </div>

        <!-- PASSWORD -->
<div class="field">
  <label class="lbl" for="password">Password</label>
  <div class="input-wrap">
    <span class="ico">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </span>

    <!-- SIRF YE EK HI PASSWORD INPUT HONA CHAHIYE -->
    <input type="password" id="password" name="password" placeholder="Enter your password" autocomplete="current-password"/>

    <button type="button" class="eye-btn" id="eyeBtn">
      <svg id="eyeOn" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
      <svg id="eyeOff" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none">
        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
        <line x1="1" y1="1" x2="23" y2="23"/>
      </svg>
    </button>
  </div>
  <div class="err" id="err-pw">
    <span id="err-pw-t"></span>
  </div>
</div>

            <button type="button" class="eye-btn" id="eyeBtn">
              <svg id="eyeOn" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
              <svg id="eyeOff" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                <line x1="1" y1="1" x2="23" y2="23"/>
              </svg>
            </button>
          </div>
          <div class="err" id="err-pw">
            <span id="err-pw-t"></span>
          </div>
        </div>

        <div class="row-mid">
          <label class="remember">
            <input type="checkbox" id="remember"/> Remember me
          </label>
          <a href="#" class="forgot">Forgot password?</a>
        </div>

        <button type="submit" class="btn-login" id="btnLogin">
          <div class="btn-inner">
            <div class="spinner" id="spinner"></div>
            <span class="btn-lbl">Initialize Scan</span>
          </div>
        </button>

        <div class="divider"></div>
      </form>
    </div>

    <div class="card-footer">
      <p>New to Lookmax AI? <a href="/">Sign in to continue →</a></p>
      <div class="secure">
        <div class="secure-dot"></div>
        256-bit encrypted · AI-secured session
      </div>
    </div>
  </div>
</div>

<script>
/* rain */
(function () {
  const canvas = document.getElementById('rain');
  const ctx = canvas.getContext('2d');
  let drops = [];

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    drops = Array.from({ length: 120 }, () => ({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      len: Math.random() * 18 + 8,
      speed: Math.random() * 3 + 2,
      opacity: Math.random() * 0.4 + 0.1
    }));
  }

  window.addEventListener('resize', resize);
  resize();

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    drops.forEach(d => {
      ctx.strokeStyle = `rgba(0,194,255,${d.opacity})`;
      ctx.lineWidth = 0.6;
      ctx.beginPath();
      ctx.moveTo(d.x, d.y);
      ctx.lineTo(d.x - 1, d.y + d.len);
      ctx.stroke();

      d.y += d.speed;
      if (d.y > canvas.height) {
        d.y = -d.len;
        d.x = Math.random() * canvas.width;
      }
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

const g = id => document.getElementById(id);

function showUserError(msg) {
  const input = g('username');
  input.classList.add('invalid');
  input.classList.remove('valid');
  g('err-user-t').textContent = msg;
  g('err-user').classList.add('show');
}

function clearUserError() {
  g('username').classList.remove('invalid');
  g('err-user').classList.remove('show');
}

function validUser() {
  g('username').classList.remove('invalid');
  g('username').classList.add('valid');
  g('err-user').classList.remove('show');
}

function showPwError(msg) {
  const input = g('password');
  input.classList.add('invalid');
  input.classList.remove('valid');
  g('err-pw-t').textContent = msg;
  g('err-pw').classList.add('show');
}

function clearPwError() {
  g('password').classList.remove('invalid');
  g('err-pw').classList.remove('show');
}

function validPw() {
  g('password').classList.remove('invalid');
  g('password').classList.add('valid');
  g('err-pw').classList.remove('show');
}

function validateUsername(val, live = false) {
  if (!val.trim()) {
    if (!live) showUserError('Username is required');
    else clearUserError();
    return false;
  }
  validUser();
  return true;
}

function validatePassword(val, live = false) {
  if (!val.trim()) {
    if (!live) showPwError('Password is required');
    else clearPwError();
    return false;
  }

  if (val.length < 6) {
    showPwError('Password must be at least 6 characters');
    return false;
  }

  validPw();
  return true;
}

g('username').addEventListener('input', e => validateUsername(e.target.value, true));
g('username').addEventListener('blur', e => validateUsername(e.target.value));
g('password').addEventListener('input', e => validatePassword(e.target.value, true));
g('password').addEventListener('blur', e => validatePassword(e.target.value));

g('eyeBtn').addEventListener('click', () => {
  const pw = g('password');
  const show = pw.type === 'password';
  pw.type = show ? 'text' : 'password';
  g('eyeOn').style.display = show ? 'none' : 'block';
  g('eyeOff').style.display = show ? 'block' : 'none';
});

/* IMPORTANT:
   Ye form submit ko prevent nahi karega unless validation fail ho.
   Isliye passport route /login tak request pahunch jayegi.
*/
g('loginForm').addEventListener('submit', function(e) {
  const username = g('username').value.trim();
  const password = g('password').value.trim();

  const ok1 = validateUsername(username);
  const ok2 = validatePassword(password);

  if (!ok1 || !ok2) {
    e.preventDefault();
    return;
  }

  // loading animation only
  const btn = g('btnLogin');
  btn.classList.add('loading');
  btn.disabled = true;
  g('spinner').style.display = 'block';
});
</script>
</body>
</html>